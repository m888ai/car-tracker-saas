generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USERS ============

model User {
  id            String    @id @default(cuid())
  firebaseUid   String    @unique
  email         String    @unique
  name          String?
  avatarUrl     String?
  plan          Plan      @default(FREE)
  stripeCustomerId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  cars          Car[]
  serviceRecords ServiceRecord[]
  comparableSales ComparableSale[]
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

// ============ VEHICLES ============

model Car {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  make          String
  model         String
  year          Int
  nickname      String?
  color         String?
  vin           String?
  licensePlate  String?
  currentMileage Int?
  purchaseDate  DateTime?
  purchasePrice Decimal?
  imageUrl      String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  serviceRecords ServiceRecord[]
  comparableSales ComparableSale[]
  valuations    Valuation[]

  @@index([userId])
}

// ============ SERVICE RECORDS ============

model ServiceRecord {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  carId         String
  car           Car       @relation(fields: [carId], references: [id], onDelete: Cascade)

  date          DateTime
  type          ServiceType
  customType    String?
  description   String
  mileage       Int?
  cost          Decimal   @default(0)
  vendor        String?
  location      String?
  notes         String?
  receiptUrl    String?
  photos        String[]

  reminderMiles Int?
  reminderDate  DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([carId])
  @@index([date])
}

enum ServiceType {
  OIL_CHANGE
  TIRES
  BRAKES
  BATTERY
  TRANSMISSION
  INSPECTION
  REGISTRATION
  INSURANCE
  WASH_DETAIL
  REPAIR
  MAINTENANCE
  UPGRADE
  FUEL
  OTHER
}

// ============ VALUATION ============

model ComparableSale {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  carId         String
  car           Car       @relation(fields: [carId], references: [id], onDelete: Cascade)

  source        String    // bat, carsandbids, hagerty, manual
  sourceName    String
  sourceUrl     String?
  
  make          String
  model         String
  year          Int
  price         Decimal
  saleDate      DateTime
  mileage       Int?
  condition     String?
  transmission  String?
  description   String?
  imageUrl      String?
  location      String?

  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([carId])
}

model Valuation {
  id            String    @id @default(cuid())
  carId         String
  car           Car       @relation(fields: [carId], references: [id], onDelete: Cascade)

  estimateLow   Decimal
  estimateMid   Decimal
  estimateHigh  Decimal
  confidence    String    // low, medium, high
  basedOn       Int       // number of comparable sales
  
  calculatedAt  DateTime  @default(now())

  @@index([carId])
}
